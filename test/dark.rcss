/* Тёмная тема Ryukon */

Window {
    background: #1e1e1e;
    color: #d4d4d4;
    font-family: Segoe UI;
    font-size: 11;
}

Button {
    background: #9800d4ff;
    color: #ffffff;
    font-weight: bold;
}

Label {
    color: #d4d4d4;
}

Input {
    background: #2d2d2d;
    color: #d4d4d4;
}

TextArea {
    background: #422121ff;
    color: #d4d4d4;
}